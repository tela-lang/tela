component Hero {
  prop onStart: Function

  view {
    div {
      style {
        text-align: "center"
        padding: "100px 24px"
        background: "linear-gradient(135deg, #34786e 0%, #1a4a42 100%)"
        color: "white"
        min-height: "100vh"
        display: "flex"
        flex-direction: "column"
        align-items: "center"
        justify-content: "center"
      }
      div {
        style { font-size: "18px" font-weight: "700" letter-spacing: "0.18em" text-transform: "uppercase" opacity: "0.7" margin-bottom: "20px" }
        content: "Tela"
      }
      h1 {
        style { font-size: "52px" font-weight: "800" margin: "0 0 20px" letter-spacing: "-1.5px" line-height: "1.1" max-width: "680px" }
        content: "Write frontend like you write backend."
      }
      p {
        style { font-size: "19px" opacity: "0.8" margin: "0 0 48px" max-width: "520px" line-height: "1.7" }
        content: "Familiar brace syntax, explicit types, scoped styles. Compiles to vanilla JS and CSS. Works with Spring Boot, Express, or any server."
      }
      div {
        style { display: "flex" gap: "16px" justify-content: "center" flex-wrap: "wrap" margin-bottom: "32px" }
        button {
          @click: onStart("introduction")
          style { background: "white" color: "#34786e" border: "none" padding: "14px 32px" border-radius: "8px" font-size: "16px" font-weight: "700" cursor: "pointer" }
          content: "Get Started"
        }
        button {
          @click: onStart("getting-started")
          style { background: "transparent" color: "white" border: "2px solid rgba(255,255,255,0.5)" padding: "14px 32px" border-radius: "8px" font-size: "16px" font-weight: "600" cursor: "pointer" }
          content: "Installation"
        }
      }
      a {
        href: "https://www.npmjs.com/package/@tela-lang/tela"
        style { display: "inline-flex" align-items: "center" gap: "8px" background: "rgba(255,255,255,0.12)" border: "1px solid rgba(255,255,255,0.25)" border-radius: "20px" padding: "8px 18px" font-size: "14px" font-weight: "600" color: "white" text-decoration: "none" letter-spacing: "0.3px" }
        content: "npm: @tela-lang/tela"
      }
    }
  }
}
